# Opcion A: Multi-dominio (recomendado)
# Usa un archivo JSON y mantenlo fuera de git
SMTP_DOMAINS_FILE=domains.json

# Ejemplo: copia domains.example.json a domains.json y edita tus credenciales

# Opcion B: Un solo dominio (fallback)
# SMTP_DOMAIN=tu-dominio.com
# SMTP_HOST=smtp.migadu.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=no-reply@tu-dominio.com
# SMTP_PASS=TU_PASSWORD
